# Copy this file to .env and fill in your own values.
# NEVER commit .env or share these values with anyone (including me).

GEMINI_API_KEY=your-gemini-key-here

# Sepolia testnet RPC endpoint. Public default works but is rate-limited;
# a free Infura/Alchemy Sepolia endpoint is more reliable.
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# TESTNET private key ONLY. Generate a fresh wallet for this project,
# fund it with a few cents of Sepolia ETH from a faucet (e.g.
# sepoliafaucet.com or the Alchemy faucet), and use nothing else.
# Never reuse a real/mainnet key here.
TESTNET_PRIVATE_KEY=0xyour_testnet_only_private_key
